{
  "name": "csv-quick",
  "version": "1.1.0",
  "description": "Zero-dep RFC 4180 CSV parser and serializer. Quoted fields, escaped quotes, custom delimiters, headers, BOM stripping.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./parse": "./src/parse.js",
    "./stringify": "./src/stringify.js"
  },
  "files": [
    "src/",
    "cli.js",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "csv-quick": "cli.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:coverage": "c8 node --test test/*.test.js",
    "lint": "eslint src/ cli.js test/",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "csv",
    "parser",
    "serializer",
    "rfc4180",
    "zero-dependency",
    "tsv",
    "bom"
  ],
  "license": "MIT",
  "author": "sulthonzh",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sulthonzh/csv-quick.git"
  },
  "homepage": "https://github.com/sulthonzh/csv-quick",
  "bugs": {
    "url": "https://github.com/sulthonzh/csv-quick/issues"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  }
}
